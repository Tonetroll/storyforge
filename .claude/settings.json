{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .venv/Scripts/python.exe && .venv/Scripts/python run.py review --all || true",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Checking review queue..."
          }
        ]
      }
    ]
  }
}
