.venv/
.env
__pycache__/
*.pyc
.tmp/

# Legacy global runtime data (pre-channel; now archived)
outputs/ideas/**/*.json
outputs/ideas/**/*.txt
logs/*.log
metrics/*.jsonl
memory/run_index.jsonl
memory/trainset.jsonl
memory/compiled/*.json

# Per-channel runtime data -- track each channel's profile.md, seeds/, and the
# review journal (review/human_review.md = the durable source of truth). The rest
# is disposable runtime data.
channels/*/outputs/**
channels/*/logs/**
channels/*/metrics/**
channels/*/memory/**
channels/*/review/*
!channels/*/review/human_review.md

# Archived pre-channel demo artifacts
archive/**

# Craft trainset grows at runtime; the doctrine (craft/principles.md) is tracked
craft/trainset.jsonl

# local safety backups (auto-copied before risky edits)
backups/
